__pycache__/
*.py[cod]
*$py.class
*.so
.env
.env.*.bak
*.db
*.sqlite3
uploads/
.venv/
venv/
.idea/
.vscode/
.claude/
*.egg-info/
dist/
build/
*.log
node_modules/
.DS_Store
Thumbs.db
pgdata/
*.pem
*.key
*.cert

# Campaign data files — never commit raw datasets to git.
# Imported into the DB via the superadmin upload endpoints and then removed locally.
*.xlsx
*.xls
*.csv

# Terraform — state is in S3, secrets in tfvars
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfstate.backup
terraform/terraform.tfvars
terraform/*.tfvars
!terraform/terraform.tfvars.example
crash.log
crash.*.log
docs/

# Android companion app — build outputs, local SDK config, signing material.
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/.idea/
android/captures/
*.keystore
*.jks
keystore.properties

# Built APK artifacts and the local serve directory contents (the APK is a
# build/CI artifact, never committed; the directory itself is kept via .gitkeep).
*.apk
apk/*
!apk/.gitkeep
