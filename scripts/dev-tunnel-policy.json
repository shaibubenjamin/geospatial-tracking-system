{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "StartPortForwardToBastionOnly",
      "Effect": "Allow",
      "Action": "ssm:StartSession",
      "Resource": [
        "arn:aws:ec2:us-east-1:387526361725:instance/i-0da32cbe872649cf7",
        "arn:aws:ssm:us-east-1:387526361725:document/AWS-StartPortForwardingSessionToRemoteHost"
      ]
    },
    {
      "Sid": "ManageOwnSessionsOnly",
      "Effect": "Allow",
      "Action": [
        "ssm:TerminateSession",
        "ssm:ResumeSession"
      ],
      "Resource": "arn:aws:ssm:us-east-1:387526361725:session/${aws:username}-*"
    },
    {
      "Sid": "StartStopBastionOnly",
      "Effect": "Allow",
      "Action": [
        "ec2:StartInstances",
        "ec2:StopInstances"
      ],
      "Resource": "arn:aws:ec2:us-east-1:387526361725:instance/i-0da32cbe872649cf7"
    },
    {
      "Sid": "DescribeReadOnly",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeInstances",
        "ec2:DescribeInstanceStatus",
        "ssm:DescribeInstanceInformation"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ReadDevDbCredentialOnly",
      "Effect": "Allow",
      "Action": "secretsmanager:GetSecretValue",
      "Resource": "arn:aws:secretsmanager:us-east-1:387526361725:secret:mda-dashboard/app-dev-password-*"
    }
  ]
}
