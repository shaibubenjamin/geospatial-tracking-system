DATABASE_URL=postgresql+asyncpg://DB_USER:DB_PASSWORD@DB_HOST:5432/geospatial_tracking_system
DATABASE_URL_SYNC=postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/geospatial_tracking_system
SECRET_KEY=change-this-to-a-long-random-secret-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256
ENVIRONMENT=production

# Superadmin bootstrap (only consulted on first startup if no matching user exists)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-this-superadmin-password
SUPERADMIN_EMAIL=superadmin@geospatial.local

# Symmetric-encryption key for CommCare credentials stored in the DB.
# Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SYNC_ENCRYPTION_KEY=

# Redis connection URL (used by the API and the sync_worker job queue).
# In docker-compose this is injected as redis://redis:6379/0.
REDIS_URL=redis://redis:6379/0

# Error tracking (optional). When SENTRY_DSN is empty, Sentry is a no-op.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# Comma-separated CORS allowlist. Defaults to first-party origins when unset.
ALLOWED_ORIGINS=

# Root log level for the JSON structured logger.
LOG_LEVEL=INFO

# Optional reverse-mirror target (on-prem Postgres). Leave blank in production.
ONPREM_BACKUP_DATABASE_URL=

# ── Outbound email (Report a Concern notifications) ────────────────────────
# When a user submits a report via the dashboard's "Report a Concern" widget,
# the app emails the programme owners (list hard-coded in app/services/notifier.py).
# All SMTP_* below are OPTIONAL — if SMTP_HOST is empty, notifications are silently
# skipped (the report is still saved to Postgres) and the HTTP endpoint stays healthy.
#
# Recommended production setup: AWS SES (email-smtp.<region>.amazonaws.com) or
# Office 365 (smtp.office365.com), each on port 587 with STARTTLS.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
# Comma-separated override of the hard-coded recipient list. Leave empty in prod
# to use the code-owned list; set for staging so tests don't email real owners.
REPORT_RECIPIENTS=

# ── Android companion app: OTA self-distribution + version gate ──────────────
# See docs/apk-app-blueprint.md. The signed APK is served as a static download
# from this server and the app is gated by versionCode (a monotonic integer =
# git commit count). The app sends X-App-Version-Code on every request.
#
# Force-update ordering rule: publish the new APK to APK_DIR FIRST, then raise
# MIN_VERSION_CODE and restart. Never raise MIN_VERSION_CODE before the new APK
# is live, or existing installs lock out with no upgrade path.
#
# MIN_VERSION_CODE = 0 disables the gate (default). Set it to the lowest
# versionCode you still allow to sync; anything below it gets HTTP 426.
MIN_VERSION_CODE=0
LATEST_VERSION_CODE=0
LATEST_VERSION_NAME=0.1
UPDATE_URL=/apk

# Directory the CI pipeline uploads the signed APK to and that /apk serves
# from. In production this is a host directory bind-mounted into the container
# (see deploy/docker-compose.prod.yml). Leave unset locally to use ./apk.
APK_DIR=/var/app-apk
APK_FILENAME=eritas-latest.apk
